{{ if eq .chezmoi.os "windows" -}}
$packages = @(
    "Neovim.Neovim",
    "Git.Git",
    "Microsoft.PowerShell",
    "AgileBits.1Password",
    "AgileBits.1Password.CLI",
    "Mozilla.Firefox",
    "Google.Chrome",
    "VSCodium.VSCodium",
    "Schniz.fnm",
    "Starship.Starship",
    "Microsoft.WindowsTerminal",
    "BurntSushi.ripgrep.MSVC",
    "junegunn.fzf",
    "sharkdp.fd",
    "eza-community.eza",
    "ajeetdsouza.zoxide",
    "Anthropic.ClaudeCode"  # Verify: run 'winget search "Claude Code"' to confirm ID
)

foreach ($pkg in $packages) {
    $result = winget list --id $pkg --exact --accept-source-agreements 2>&1
    if ($LASTEXITCODE -eq 0) {
        Write-Host "$pkg already installed, skipping."
    } else {
        Write-Host "Installing $pkg..."
        winget install --id $pkg --scope user --silent --accept-package-agreements --accept-source-agreements
    }
}


if (-not (Get-Command scoop -ErrorAction SilentlyContinue)) {
    Write-Host "Installing Scoop..."
    Set-ExecutionPolicy RemoteSigned -Scope CurrentUser -Force
    Invoke-RestMethod -Uri https://get.scoop.sh | Invoke-Expression
}

scoop bucket add extras

$scoop_packages = @(
    "ghq",
    "git-aliases"
)

foreach ($pkg in $scoop_packages) {
    $installed = scoop list $pkg 2>&1 | Select-String $pkg
    if ($installed) {
        Write-Host "$pkg already installed, skipping."
    } else {
        Write-Host "Installing $pkg..."
        scoop install $pkg
    }
}

{{- end }}
